# =============================================================================
# StitchUp Backend - Environment Variables
# Copy this file as .env and fill in the values
# =============================================================================

# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_NAME=stitchup_db
DB_SYNCHRONIZE=false
DB_LOGGING=true

# JWT
JWT_SECRET=your_very_long_random_secret_key_min_32_characters
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=another_very_long_random_secret_key_min_32_characters
JWT_REFRESH_EXPIRY=30d

# OTP
OTP_LENGTH=6
OTP_EXPIRY_SECONDS=300
MAX_OTP_ATTEMPTS=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM_NAME=StitchUp

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Logging
LOG_LEVEL=debug
